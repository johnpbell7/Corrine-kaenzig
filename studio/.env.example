# Copy to .env and fill in. Get the project id after `sanity init` / from sanity.io/manage.
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Only needed to run the one-time seed (scripts/seed.mjs).
# Create at sanity.io/manage -> API -> Tokens, with Editor (write) permission.
SANITY_API_TOKEN=your_editor_token
